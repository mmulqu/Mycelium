{
  "_info": {
    "name": "SD 1.5 Inpaint",
    "vram": "~4GB",
    "checkpoint": "v1-5-pruned-emaonly.safetensors",
    "note": "Change ckpt_name to match your actual checkpoint file."
  },
  "1": {
