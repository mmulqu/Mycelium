      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["7", 0],
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": "__DENOISE__"
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["8", 0],
      "vae": ["1", 2]
    }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["9", 0],
      "filename_prefix": "mycelium"
    }
  }
}
