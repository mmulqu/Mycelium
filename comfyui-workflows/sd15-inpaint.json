      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__NEGATIVE_PROMPT__",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__INPUT_IMAGE__"
    }
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__MASK__"
    }
  },
  "6": {
    "class_type": "ImageToMask",
    "inputs": {
      "image": ["5", 0],
      "channel": "red"
    }
  },
  "7": {
    "class_type": "VAEEncodeForInpaint",
    "inputs": {
      "pixels": ["4", 0],
      "vae": ["1", 2],
      "mask": ["6", 0],
      "grow_mask_by": 8
    }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
